# --- Required ---

# Public URL this proxy is reachable at. Used to build the OIDC redirect URI
# (typically <OWN_SERVER_URL>/auth/callback) — whatever you register in your
# IdP must match. No trailing slash.
OWN_SERVER_URL=https://playwright-mcp.example.com

# Base URL of your OpenID Connect provider. The proxy fetches
# <AUTH_SERVER_URL>/.well-known/openid-configuration to discover endpoints.
# Examples:
#   Authelia:     https://auth.example.com
#   Keycloak:     https://keycloak.example.com/realms/<realm>
#   Authentik:    https://authentik.example.com/application/o/<slug>
#   Auth0:        https://<tenant>.auth0.com
#   Okta:         https://<tenant>.okta.com
AUTH_SERVER_URL=https://auth.example.com

# OAuth client secret issued by your IdP for the client below.
CLIENT_SECRET=replace-with-your-oidc-client-secret

# --- Optional (sensible defaults; override if needed) ---

# OAuth client ID registered in your IdP. Default matches the suggested
# name in the README; change it if you registered the client under another ID.
CLIENT_ID=playwright-mcp-server

# Comma-separated scopes the access token must carry. `openid` is added by
# the OIDC client automatically; `profile` and `email` are the usual extras.
REQUIRED_SCOPES=profile,email

# Expected `aud` claim on the access token. Leave blank to skip audience
# validation. Set it if your IdP issues audience-scoped tokens (e.g. Auth0).
AUDIENCE=

# Upstream playwright-mcp URL on the internal docker network. The service
# name `playwright` matches docker-compose.yml — only change this if you run
# the upstream outside the bundled compose stack.
UPSTREAM_MCP_URL=http://playwright:8931/mcp

# Where this proxy listens inside the container. The published port in
# docker-compose.yml is 8929; if you change SERVER_PORT, update the compose
# mapping to match.
SERVER_HOST=0.0.0.0
SERVER_PORT=8929

# --- Optional: machine-key (headless) auth ---

# Static bearer token that, when sent as `Authorization: Bearer <key>`,
# authenticates the caller as a synthetic "machine" principal — no IdP
# round-trip, no browser flow. Runs in parallel with the OAuth path on
# the same /mcp endpoint; leave unset (or empty) to disable it.
#
# Tradeoffs vs. OAuth:
#   - No per-user identity. Every machine caller is the same principal.
#   - No clock-based expiry. The key is valid until you rotate it.
#   - Not revocable via your IdP. The secret IS the access control.
#   - Rotation is manual: edit this file, restart the proxy, update every
#     machine client.
#
# Use it for cron jobs, CI runners, headless containers — anywhere a
# browser-based OAuth flow doesn't work. For interactive use (Claude Code
# on a laptop), prefer OAuth.
#
# Must be at least 32 characters. The proxy refuses to start if it's
# shorter, so a typo can't silently weaken auth. Generate one with:
#   openssl rand -base64 32
MACHINE_API_KEY=
